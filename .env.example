# ============================================
# Clone Talking — Environment Variables
# ============================================
# Copy this file from .env.example and fill in your values.
# DO NOT commit this file.
# ============================================

# OpenRouter — LLM (all models via single key)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model to use via OpenRouter
# Browse models at: https://openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# OpenAI — Whisper speech-to-text only
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# VoiSpark — Text-to-speech with voice cloning
# Get your key at: https://voispark.com → Settings → API Tokens
VOISPARK_API_KEY=

# VoiSpark provider and model (check available options at GET /api/tts/models)
# Example providers: fish-audio, elevenlabs, openai, cartesia
VOISPARK_PROVIDER=fish-audio
VOISPARK_MODEL_ID=s1

# ngrok — HTTPS tunnel (required for mic access on Android Chrome)
# Get your token at: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# Local server port (optional, default: 3000)
PORT=3000
